<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="字体" android:textStyle="bold" android:textSize="15sp"/>

    <RadioGroup android:id="@+id/fontGroup"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:layout_marginTop="6dp"/>

    <TextView android:id="@+id/sizeLabel"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" android:text="字号" android:textStyle="bold" android:textSize="15sp"/>

    <SeekBar android:id="@+id/sizeSeek"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/spacingLabel"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="字间距" android:textStyle="bold" android:textSize="15sp"/>

    <SeekBar android:id="@+id/spacingSeek"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/lineHeightLabel"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="行间距" android:textStyle="bold" android:textSize="15sp"/>

    <SeekBar android:id="@+id/lineHeightSeek"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="字体颜色" android:textStyle="bold" android:textSize="15sp"/>

    <LinearLayout android:id="@+id/fontColorRow"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"/>

    <CheckBox android:id="@+id/preserveStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="保留电子书自带排版（字体/段落格式）"
        android:textSize="14sp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#888"
        android:textSize="12sp"
        android:text="开启：跟随出版社原始 CSS；字体/字号/字距/行距设置不再生效。\n关闭：使用阅读器默认排版，字体字号字距行距可调。"/>
</LinearLayout>
