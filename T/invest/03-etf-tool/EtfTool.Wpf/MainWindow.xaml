
<Controls:MetroWindow x:Class="EtfTool.Wpf.MainWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
                     mc:Ignorable="d"
                     Title="大A ETF工具" Height="900" Width="1200"
                     GlowBrush="{DynamicResource AccentColorBrush}"
                     WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <Binding Path="MainViewModel" Source="{StaticResource Locator}" />
    </Window.DataContext>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="12" Background="White" CornerRadius="8" Padding="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="4" BorderBrush="#CCCCCC" BorderThickness="1">
                    <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Padding="12,10"
                             FontSize="14"
                             BorderThickness="0"
                             Controls:TextBoxHelper.Watermark="输入ETF代码或名称搜索..."
                             Controls:TextBoxHelper.ClearTextButton="True">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </Border>

                <Button Grid.Column="1" 
                        Command="{Binding SearchCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        Margin="0,0,8,0"
                        Padding="12,10"
                        FontSize="14"
                        FontWeight="Bold"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1a73e8" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1557b0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    搜索
                </Button>

                <ComboBox Grid.Column="2"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding AvailableDataSources}"
                          SelectedItem="{Binding SelectedDataSource}"
                          Padding="8,10"
                          FontSize="14"
                          BorderBrush="#CCCCCC"
                          BorderThickness="1">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="3"
                        Command="{Binding ClearCacheCommand}"
                        Padding="12,10"
                        Background="#EEEEEE"
                        Foreground="#333333"
                        FontSize="14"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">
                    清除缓存
                </Button>
            </Grid>
        </Border>

        <TextBlock Grid.Row="0" Margin="12,60,12,0" 
                   Text="{Binding ErrorMessage}" 
                   Foreground="Red" 
                   FontSize="13"
                   HorizontalAlignment="Left" />

        <Grid Grid.Row="1" Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,8,0" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="搜索结果" FontSize="16" FontWeight="Bold" 
                               Foreground="#333333" Margin="12,12,0,8" />

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,12,12,8" HorizontalAlignment="Right">
                        <TextBlock Text="共 " Foreground="#999999" FontSize="12" />
                        <TextBlock Text="{Binding SearchResults.Count}" 
                                   Foreground="{DynamicResource AccentColorBrush}" 
                                   FontWeight="Bold" FontSize="12" />
                        <TextBlock Text=" 条" Foreground="#999999" FontSize="12" />
                    </StackPanel>

                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding SearchResults}"
                             SelectedValuePath="Code"
                             SelectedValue="{Binding SelectedEtfCode}"
                             MouseDoubleClick="ListBox_MouseDoubleClick"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" 
                                        BorderBrush="#EEEEEE" 
                                        BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Code}" 
                                                   FontWeight="Bold" 
                                                   Width="80" 
                                                   Foreground="{DynamicResource AccentColorBrush}"
                                                   FontFamily="Consolas" FontSize="14" />
                                        <TextBlock Text="{Binding Name}" FontSize="14" Foreground="#333333" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentColorBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Background="Transparent" />
            </Border>
        </Grid>
    </Grid>
</Controls:MetroWindow>
