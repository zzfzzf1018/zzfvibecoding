<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5DC"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#8B4513"
        android:gravity="center"
        android:padding="10dp"
        android:text="红方走棋"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tv_thinking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF3CD"
        android:gravity="center"
        android:padding="6dp"
        android:text="AI 思考中..."
        android:textColor="#856404"
        android:textSize="13sp"
        android:visibility="invisible" />

    <com.chess.chinese.ui.ChessBoardView
        android:id="@+id/chess_board_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 棋谱区域 -->
    <ScrollView
        android:id="@+id/scroll_notation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFDE7"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp">

        <TextView
            android:id="@+id/tv_notation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#333333"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp" />
    </ScrollView>

    <!-- 按钮区域 第一行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:backgroundTint="#6C757D"
            android:text="返回"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_undo"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:backgroundTint="#D4A017"
            android:text="悔棋"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_hint"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:backgroundTint="#0288D1"
            android:text="提示"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:backgroundTint="#6A1B9A"
            android:text="存档"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_restart"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:backgroundTint="#CC0000"
            android:text="重开"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_more"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:backgroundTint="#455A64"
            android:text="更多"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="6dp" />

</LinearLayout>
