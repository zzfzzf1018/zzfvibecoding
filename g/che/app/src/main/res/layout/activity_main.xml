<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5DC"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="中 国 象 棋"
        android:textColor="#8B0000"
        android:textSize="36sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_pvp"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#CC0000"
        android:text="双人对战"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

    <CheckBox
        android:id="@+id/cb_auto_flip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="双人对战时自动翻转棋盘"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:text="AI 难度设置"
        android:textColor="#333333"
        android:textSize="16sp" />

    <RadioGroup
        android:id="@+id/rg_difficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rb_easy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="简单"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rb_medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:checked="true"
            android:text="中等"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rb_hard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="困难"
            android:textSize="15sp" />
    </RadioGroup>

    <Button
        android:id="@+id/btn_pve"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#1A5276"
        android:text="人机对战"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_puzzle"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#2E7D32"
        android:text="残局挑战"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_bluetooth"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#0277BD"
        android:text="蓝牙对战"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_load"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:backgroundTint="#6A1B9A"
        android:text="读取存档"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

</LinearLayout>
