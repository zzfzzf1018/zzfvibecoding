<Window x:Class="PdfToMarkdown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF转Markdown工具 - A股年报解析" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="PDF转Markdown工具" FontSize="24" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text="支持A股上市公司年报PDF解析，自动提取季度财务数据" 
                       FontSize="13" Foreground="#666" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White" Padding="8,4">
                <TextBlock x:Name="TxtFilePath" Text="请选择PDF文件..." VerticalAlignment="Center" 
                           Foreground="#999" FontSize="13" TextTrimming="CharacterEllipsis"/>
            </Border>

            <Button Grid.Column="1" Content="选择文件" Style="{StaticResource BtnStyle}" 
                    Margin="8,0,0,0" Click="BtnSelectFile_Click"/>
            <Button Grid.Column="2" Content="开始转换" Style="{StaticResource BtnStyle}" 
                    Margin="8,0,0,0" Click="BtnConvert_Click" x:Name="BtnConvert" IsEnabled="False"/>
            <Button Grid.Column="3" Content="提取财务" Style="{StaticResource BtnStyle}" 
                    Margin="8,0,0,0" Click="BtnExtractFinancial_Click" x:Name="BtnExtract" IsEnabled="False"
                    Background="#4CAF50"/>
            <Button Grid.Column="4" Content="保存" Style="{StaticResource BtnStyle}" 
                    Margin="8,0,0,0" Click="BtnSave_Click" x:Name="BtnSave" IsEnabled="False"
                    Background="#FF9800"/>
        </Grid>

        <!-- Main Content -->
        <TabControl Grid.Row="2" x:Name="TabMain">
            <TabItem Header="Markdown输出">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Raw Markdown -->
                    <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Markdown源码" FontWeight="Bold" 
                                       Margin="8,8,8,4" Foreground="#555"/>
                            <TextBox x:Name="TxtMarkdown" 
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas, Microsoft YaHei"
                                     FontSize="12" BorderThickness="0" Margin="8"
                                     IsReadOnly="True"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

                    <!-- Preview -->
                    <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="文本预览" FontWeight="Bold" 
                                       Margin="8,8,8,4" Foreground="#555"/>
                            <TextBox x:Name="TxtPreview" 
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Microsoft YaHei"
                                     FontSize="12" BorderThickness="0" Margin="8"
                                     IsReadOnly="True"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="财务数据">
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="提取的财务数据" FontWeight="Bold" 
                                   Margin="8,8,8,4" Foreground="#555"/>
                        <TextBox x:Name="TxtFinancial" 
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Microsoft YaHei"
                                 FontSize="12" BorderThickness="0" Margin="8"
                                 IsReadOnly="True"/>
                    </DockPanel>
                </Border>
            </TabItem>

            <TabItem Header="PDF信息">
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="PDF文件信息" FontWeight="Bold" 
                                   Margin="8,8,8,4" Foreground="#555"/>
                        <TextBox x:Name="TxtInfo" 
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Microsoft YaHei"
                                 FontSize="12" BorderThickness="0" Margin="8"
                                 IsReadOnly="True"/>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="3" Margin="0,8,0,0" Background="#E8E8E8" CornerRadius="4" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Text="就绪" VerticalAlignment="Center" Foreground="#555"/>
                <ProgressBar x:Name="ProgressBar" Grid.Column="1" Width="200" Height="16" 
                             Visibility="Collapsed" Minimum="0" Maximum="100"/>
            </Grid>
        </Border>
    </Grid>
</Window>
