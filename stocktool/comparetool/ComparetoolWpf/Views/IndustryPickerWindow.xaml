<Window x:Class="ComparetoolWpf.Views.IndustryPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择行业（可多选）" Height="520" Width="520"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="过滤:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox x:Name="FilterBox" Width="200" TextChanged="FilterBox_TextChanged"/>
            <Button Content="全选" Margin="10,0,0,0" Padding="8,2" Click="SelectAll_Click"/>
            <Button Content="全不选" Margin="6,0,0,0" Padding="8,2" Click="ClearAll_Click"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="确定" Width="80" IsDefault="True" Click="Ok_Click"/>
            <Button Content="取消" Width="80" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
        <ListBox x:Name="IndustryList" SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
