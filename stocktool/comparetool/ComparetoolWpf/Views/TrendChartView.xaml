<UserControl x:Class="ComparetoolWpf.Views.TrendChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <DockPanel Margin="8">
        <Border DockPanel.Dock="Top" Padding="6" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="搜索:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="260" IsEditable="True" StaysOpenOnEdit="True"
                              Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SearchSelected}"
                              IsTextSearchEnabled="False" />
                    <Button Content="加入" Margin="10,0,0,0" Padding="10,2" Command="{Binding AddStockCommand}" />
                    <Button Content="从自选导入" Margin="6,0,0,0" Padding="10,2" Command="{Binding ImportWatchlistCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="股票:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ListBox Width="500" Height="60" ItemsSource="{Binding SelectedStocks}"
                             SelectedItem="{Binding SelectedStocksItem}" />
                    <Button Content="移除" Margin="10,0,0,0" Padding="10,2" VerticalAlignment="Top"
                            Command="{Binding RemoveStockCommand}" />
                    <TextBlock Text="    报表:" VerticalAlignment="Center" Margin="20,0,4,0"/>
                    <ComboBox Width="120" ItemsSource="{Binding ReportKinds}" SelectedItem="{Binding SelectedReportKind}" />
                    <TextBlock Text="    报告期:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <ComboBox Width="100" ItemsSource="{Binding PeriodTypes}" SelectedItem="{Binding SelectedPeriodType}" />
                    <TextBlock Text="    指标:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <ComboBox Width="220" ItemsSource="{Binding AllMetrics}" SelectedItem="{Binding SelectedMetric}" />
                    <CheckBox Content="归一化(首期=100)" Margin="10,0,0,0" VerticalAlignment="Center"
                              IsChecked="{Binding Normalize}"
                              ToolTip="把每条曲线第一期值归为 100，方便跨股票比较涨幅"/>
                    <CheckBox Content="对数轴" Margin="10,0,0,0" VerticalAlignment="Center"
                              IsChecked="{Binding UseLogAxis}"
                              ToolTip="Y 轴改用对数刻度，适合数值跨度大或长期增长的指标"/>
                    <Button Content="绘制趋势" Margin="10,0,0,0" Padding="14,4" Command="{Binding PlotCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
        <oxy:PlotView Model="{Binding PlotModel}" />
    </DockPanel>
</UserControl>
