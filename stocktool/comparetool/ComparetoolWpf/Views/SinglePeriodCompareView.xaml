<UserControl x:Class="ComparetoolWpf.Views.SinglePeriodCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ComparetoolWpf.Converters"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <UserControl.Resources>
        <conv:NullableDoubleConverter x:Key="NumConv" />
        <conv:PercentConverter x:Key="PercentConv" />
        <conv:HighlightBackgroundConverter x:Key="HlBgConv" />
    </UserControl.Resources>

    <DockPanel Margin="8">

        <!-- 顶部：搜索 + 加载控制 -->
        <Border DockPanel.Dock="Top" Padding="6" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="股票:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="180" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="搜索" Margin="6,0" Padding="10,2" Command="{Binding SearchCommand}" />
                    <ComboBox Width="220" ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedStock}" />
                    <TextBlock Text="    报表:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <ComboBox Width="120" ItemsSource="{Binding ReportKinds}" SelectedItem="{Binding SelectedReportKind}" />
                    <TextBlock Text="    报告期:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <ComboBox Width="100" ItemsSource="{Binding PeriodTypes}" SelectedItem="{Binding SelectedPeriodType}" />
                    <Button Content="加载历史报表" Margin="10,0,0,0" Padding="10,2" Command="{Binding LoadReportsCommand}" />
                    <CheckBox Content="强制刷新(忽略缓存)" Margin="10,0,0,0" VerticalAlignment="Center"
                              IsChecked="{Binding ForceRefresh}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="基准期:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="180" ItemsSource="{Binding LoadedReports}" SelectedItem="{Binding BaseReport}"
                              DisplayMemberPath="PeriodLabel" />
                    <TextBlock Text="    对比期:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <ComboBox Width="180" ItemsSource="{Binding LoadedReports}" SelectedItem="{Binding CompareReport}"
                              DisplayMemberPath="PeriodLabel" />
                    <TextBlock Text="    高亮阈值(%):" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <TextBox Width="60" Text="{Binding HighlightThresholdPercent, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="对比" Margin="10,0,0,0" Padding="20,2" Command="{Binding CompareCommand}" />
                    <Button Content="导出..." Margin="10,0,0,0" Padding="14,2" Command="{Binding ExportComparisonCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 主体：差异表 -->
        <DataGrid ItemsSource="{Binding ComparisonRows}" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  AlternationCount="2" RowBackground="White" AlternatingRowBackground="#F8F8F8">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding IsHighlighted, Converter={StaticResource HlBgConv}}" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="指标" Binding="{Binding Item}" Width="240" />
                <DataGridTextColumn Header="基准期数值"
                                    Binding="{Binding BaseValue, Converter={StaticResource NumConv}}"
                                    Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="对比期数值"
                                    Binding="{Binding CompareValue, Converter={StaticResource NumConv}}"
                                    Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="绝对变化"
                                    Binding="{Binding AbsoluteChange, Converter={StaticResource NumConv}}"
                                    Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="变化率"
                                    Binding="{Binding ChangeRatio, Converter={StaticResource PercentConv}}"
                                    Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
